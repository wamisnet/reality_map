rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /results/{docId} {
      // Public read: 公開ページが誰でも participantId / resultId から引ける。
      allow read: if true;

      // Only the signed-in operator may create results, and only for their own uid.
      allow create: if request.auth != null
        && request.resource.data.operatorUid == request.auth.uid
        && request.resource.data.participantName is string
        && request.resource.data.participantName.size() > 0
        && request.resource.data.participantName.size() <= 64
        && request.resource.data.participantKey is string
        && request.resource.data.participantId is string
        && request.resource.data.participantId.matches('^[a-z0-9]{6,16}$')
        && request.resource.data.candidateName is string
        && request.resource.data.pref is string
        && request.resource.data.lon is number
        && request.resource.data.lat is number;

      // /edit/participants の手動マージで participantId/participantKey を統合先に
      // 書き換えるためだけの限定的な update を許可する。書き換え可能なのは
      // 下記5フィールドのみで、新しい participantId はランダムID形式必須、
      // 元レコードの operatorUid を改ざんできないように一致を要求する。
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['participantId', 'participantKey', 'mergedFrom', 'mergedAt', 'mergedBy'])
        && request.resource.data.participantId is string
        && request.resource.data.participantId.matches('^[a-z0-9]{6,16}$')
        && request.resource.data.participantKey is string
        && request.resource.data.operatorUid == resource.data.operatorUid;

      allow delete: if false;
    }

    // 候補（地点プール）— 読みは公開 (結果ページが最新画像/説明文を引き直すため)、書きはサインインオペレーターのみ
    match /candidates/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ストリーマー配下のギフト等。サインインオペレーターのみ読取
    match /streamers/{streamerId}/{document=**} {
      allow read: if request.auth != null;
      // 書き込みはサーバー側で行う想定（クライアントからは不許可）
      allow write: if false;
    }

    // 抽選アプリ専用: ギフトに「抽選済み」フラグを書き戻す限定的な update を許可。
    // 配信者本人 (auth.uid == streamerId) が、追加する2フィールドだけを merge update できる。
    // 既存フィールド (user_raw / amount / gift_name 等) は触らせない。
    match /streamers/{streamerId}/gifts/{giftId} {
      allow update: if request.auth != null
        && request.auth.uid == streamerId
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lottery_processed_at', 'lottery_processed_by']);
    }
  }
}
